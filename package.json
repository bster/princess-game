{
  "name": "princess-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Princess & Frank — Capacitor + Vite + TypeScript canvas game",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint www/js --max-warnings 0",
    "format": "prettier --write \"www/**/*.{js,html,css}\" \"tests/**/*.ts\" \"*.{ts,json}\"",
    "cap:sync": "npm run build && npx cap sync ios"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.4"
  }
}
